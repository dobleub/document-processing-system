{
    "swagger": "2.0",
    "info": {
        "contact": {}
    },
    "paths": {
        "/process/list": {
            "get": {
                "description": "List all processes with their current status",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Process"
                ],
                "summary": "List Processes",
                "responses": {
                    "200": {
                        "description": "List of Processes",
                        "schema": {
                            "$ref": "#/definitions/interfaces.OperationListResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/process/results/{id}": {
            "get": {
                "description": "Get the results of a process by its ID",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Process"
                ],
                "summary": "Get Process Results",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Process ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Process Results",
                        "schema": {
                            "$ref": "#/definitions/interfaces.OperationStatus"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "404": {
                        "description": "Process Not Found",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/process/start": {
            "post": {
                "description": "Start a new process with the provided data",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Process"
                ],
                "summary": "Start a Process",
                "parameters": [
                    {
                        "description": "Process Data",
                        "name": "data",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Process Started",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/process/status/{id}": {
            "get": {
                "description": "Get the status of a process by its ID",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Process"
                ],
                "summary": "Get Process Status",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Process ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Process Status",
                        "schema": {
                            "$ref": "#/definitions/interfaces.OperationStatus"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "404": {
                        "description": "Process Not Found",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/process/stop/{id}": {
            "post": {
                "description": "Stop a process by its ID",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Process"
                ],
                "summary": "Stop a Process",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Process ID",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Process Status",
                        "schema": {
                            "$ref": "#/definitions/interfaces.OperationStatus"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "404": {
                        "description": "Process Not Found",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/summarizer/mcp": {
            "post": {
                "description": "Handle MCP requests for summarization",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Summarizer"
                ],
                "summary": "MCP Handler for Summarizer",
                "parameters": [
                    {
                        "description": "Summarize Input",
                        "name": "data",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/interfaces.SummarizeInput"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Summarize Output",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/summarizer/summarize": {
            "post": {
                "description": "Handle http requests for summarization",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Summarizer"
                ],
                "summary": "http Handler for Summarizer",
                "parameters": [
                    {
                        "description": "Summarize Input",
                        "name": "data",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/interfaces.SummarizeInput"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/interfaces.SummarizeHTTPOutput"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/ws/status": {
            "get": {
                "description": "Get the current status of All Process connections via WebSocket",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Websocket Process"
                ],
                "summary": "Get All Process Status",
                "responses": {
                    "200": {
                        "description": "List of Processes",
                        "schema": {
                            "$ref": "#/definitions/interfaces.OperationListResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "interfaces.OperationListResponse": {
            "type": "object",
            "properties": {
                "processes": {
                    "description": "List of processes with their current status",
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/interfaces.OperationReview"
                    }
                }
            }
        },
        "interfaces.OperationProgress": {
            "type": "object",
            "properties": {
                "percentage": {
                    "type": "integer"
                },
                "processed_files": {
                    "type": "integer"
                },
                "total_files": {
                    "type": "integer"
                }
            }
        },
        "interfaces.OperationResults": {
            "type": "object",
            "properties": {
                "files_processed": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "files_to_process": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "most_frequent_words": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "total_lines": {
                    "type": "integer"
                },
                "total_words": {
                    "type": "integer"
                }
            }
        },
        "interfaces.OperationReview": {
            "type": "object",
            "properties": {
                "error": {
                    "description": "Error message if the process failed",
                    "type": "string"
                },
                "estimated_completion": {
                    "description": "Estimated completion time",
                    "type": "string"
                },
                "files_processed": {
                    "description": "List of files processed, this is added to give more insights about the process, it can be used to show the progress of the process in the frontend",
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "files_to_process": {
                    "description": "List files to process",
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "id": {
                    "description": "Unique identifier for the process",
                    "type": "string"
                },
                "started_at": {
                    "description": "Timestamp when the process started",
                    "type": "string"
                },
                "status": {
                    "description": "Current status of the process (e.g., \"pending\", \"in_progress\", \"completed\", \"failed\")",
                    "type": "string"
                }
            }
        },
        "interfaces.OperationStatus": {
            "type": "object",
            "properties": {
                "completed_at": {
                    "description": "Timestamp when the process completed",
                    "type": "string"
                },
                "error": {
                    "description": "Error message if the process failed",
                    "type": "string"
                },
                "estimated_completion": {
                    "description": "Time taken for the process to complete",
                    "type": "string"
                },
                "process_id": {
                    "description": "Unique identifier for the process",
                    "type": "string"
                },
                "progress": {
                    "description": "Progress details of the process",
                    "allOf": [
                        {
                            "$ref": "#/definitions/interfaces.OperationProgress"
                        }
                    ]
                },
                "results": {
                    "description": "Result of the process (e.g., summary, statistics)",
                    "allOf": [
                        {
                            "$ref": "#/definitions/interfaces.OperationResults"
                        }
                    ]
                },
                "started_at": {
                    "description": "Timestamp when the process started",
                    "type": "string"
                },
                "status": {
                    "description": "Current status of the process",
                    "allOf": [
                        {
                            "$ref": "#/definitions/interfaces.OperationStatusEnum"
                        }
                    ]
                }
            }
        },
        "interfaces.OperationStatusEnum": {
            "type": "string",
            "enum": [
                "PENDING",
                "RUNNING",
                "PAUSED",
                "COMPLETED",
                "FAILED",
                "STOPPED"
            ],
            "x-enum-varnames": [
                "Pending",
                "Running",
                "Paused",
                "Completed",
                "Failed",
                "Stopped"
            ]
        },
        "interfaces.SummarizeHTTPOutput": {
            "type": "object",
            "properties": {
                "file_name": {
                    "type": "string"
                },
                "file_size": {
                    "type": "integer"
                },
                "summary": {
                    "type": "string"
                }
            }
        },
        "interfaces.SummarizeInput": {
            "type": "object",
            "properties": {
                "file_path": {
                    "type": "string"
                },
                "max_length": {
                    "type": "integer"
                }
            }
        }
    }
}